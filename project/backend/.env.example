# Database Connections
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/farmdiary?schema=public
MONGODB_URI=mongodb://localhost:27017/farmdiary
REDIS_URL=redis://localhost:6379

# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# AI / LLM Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Third-Party Integrations
ZALO_APP_ID=your_zalo_app_id
ZALO_SECRET_KEY=your_zalo_secret_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Object Storage (Cloudflare R2)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=farmdiary-assets

# Email Delivery
RESEND_API_KEY=your_resend_api_key

# Security
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
ENCRYPTION_KEY=your_aes_256_key_here_must_be_32_bytes

# Observability
SENTRY_DSN=your_sentry_dsn_here
